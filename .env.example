# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is read ONLY by server.ts (Node.js process). It is never bundled into
# client-side JavaScript and never reaches the browser.
# Copy this file to .env (or .env.local) and put your real key there —
# .env / .env.local are already excluded from git via .gitignore.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
